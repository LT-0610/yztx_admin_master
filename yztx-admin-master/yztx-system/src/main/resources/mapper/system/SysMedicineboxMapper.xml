<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysMedicineboxMapper">
    
    <resultMap type="SysMedicinebox" id="SysMedicineboxResult">
        <result property="id"    column="id"    />
        <result property="medicineName"    column="medicine_name"    />
        <result property="margin"    column="margin"    />
        <result property="boxCategory"    column="box_category"    />
        <result property="expireTime"    column="expire_time"    />
        <result property="medicineFlag"    column="medicine_flag"    />
        <result property="notes"    column="notes"    />
        <result property="userId"    column="user_id"    />
    </resultMap>

    <sql id="selectSysMedicineboxVo">
        select id, medicine_name, margin, box_category, expire_time, medicine_flag,notes,user_id from sys_medicinebox
    </sql>

    <select id="selectSysMedicineboxList" parameterType="SysMedicinebox" resultMap="SysMedicineboxResult">
        <include refid="selectSysMedicineboxVo"/>
        <where>  
            <if test="medicineName != null  and medicineName != ''"> and medicine_name like concat('%', #{medicineName}, '%')</if>
            <if test="boxCategory != null  and boxCategory != ''"> and box_category = #{boxCategory}</if>
            <if test="expireTime != null "> and expire_time = #{expireTime}</if>
            <if test="medicineFlag != null  and medicineFlag != ''"> and medicine_flag = #{medicineFlag}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
        </where>
    </select>
    <select id="findAllDistinctMedicineBoxNames" parameterType="long" resultType="String">
        SELECT DISTINCT box_category
        FROM sys_medicinebox
        <where>
        <if test="userId != null "> and user_id = #{userId}</if>
        </where>
    </select>

    <insert id="insertSysMedicinebox" parameterType="SysMedicinebox">
        insert into sys_medicinebox
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null">id,</if>
            <if test="medicineName != null">medicine_name,</if>
            <if test="margin != null">margin,</if>
            <if test="boxCategory != null">box_category,</if>
            <if test="expireTime != null">expire_time,</if>
            <if test="medicineFlag != null">medicine_flag,</if>
            <if test="notes != null">notes,</if>
            <if test="userId != null">user_id,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="id != null">#{id},</if>
            <if test="medicineName != null">#{medicineName},</if>
            <if test="margin != null">#{margin},</if>
            <if test="boxCategory != null">#{boxCategory},</if>
            <if test="expireTime != null">#{expireTime},</if>
            <if test="medicineFlag != null">#{medicineFlag},</if>
            <if test="notes != null">#{notes},</if>
            <if test="userId != null">#{userId},</if>
         </trim>
    </insert>

    <update id="updateSysMedicinebox" parameterType="SysMedicinebox">
        update sys_medicinebox
        <trim prefix="SET" suffixOverrides=",">
            <if test="medicineName != null">medicine_name = #{medicineName},</if>
            <if test="margin != null">margin = #{margin},</if>
            <if test="expireTime != null">expire_time = #{expireTime},</if>
            <if test="medicineFlag != null">medicine_flag = #{medicineFlag},</if>
            <if test="notes != null">notes = #{notes},</if>
        </trim>
        where id = #{id}
    </update>



    <delete id="deleteSysMedicineboxByCategorys" parameterType="map">
        delete from sys_medicinebox where box_category = #{boxCategory}
        and user_id = #{userId}
    </delete>

    <delete id="deleteSysMedicineOfBox" parameterType="map">
        delete from sys_medicinebox where medicine_name = #{medicineName}
        and box_category = #{boxCategory}
        and user_id = #{userId}
    </delete>
</mapper>