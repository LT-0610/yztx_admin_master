<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.SysArticleMapper">

    <resultMap type="SysArticle" id="SysArticleResult">
        <result property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="author" column="author"/>
        <result property="homePage" column="home_page"/>
        <result property="status" column="status"/>
        <result property="updateTime" column="update_time"/>
        <result property="pageView" column="page_view"/>
        <result property="introduction"    column="introduction"    />
        <result property="imageText" column="image_text"/>
        <result property="pageLike" column="page_like"/>
        <result property="pageCollect" column="page_collect"/>
    </resultMap>

    <sql id="selectSysArticleVo">
        select id,
               title,
               author,
               home_page,
               status,
               update_time,
               page_view,
               introduction,
               image_text,
               page_like,
               page_collect
        from sys_article
    </sql>

    <select id="selectSysArticleList" parameterType="SysArticle" resultMap="SysArticleResult">
        <include refid="selectSysArticleVo"/>
        <where>
            <if test="title != null  and title != ''">and title like concat('%', #{title}, '%')</if>
            <if test="author != null  and author != ''">and author = #{author}</if>
            <if test="homePage != null  and homePage != ''">and home_page = #{homePage}</if>
            <if test="status != null  and status != ''">and status = #{status}</if>
            <if test="params.beginUpdateTime != null and params.beginUpdateTime != '' and params.endUpdateTime != null and params.endUpdateTime != ''">
                and update_time between STR_TO_DATE(#{params.beginUpdateTime}, '%Y-%m-%d %H:%i:%s')
                and STR_TO_DATE(#{params.endUpdateTime}, '%Y-%m-%d %H:%i:%s')
            </if>
            <if test="pageView != null ">and page_view &gt;= #{pageView}</if>
            <if test="imageText != null  and imageText != ''">and image_text = #{imageText}</if>
            <if test="pageLike != null ">and page_like &gt;= #{pageLike}</if>
            <if test="pageCollect != null ">and page_collect &gt;= #{pageCollect}</if>
        </where>
    </select>

    <select id="selectSysArticleById" parameterType="Long" resultMap="SysArticleResult">
        <include refid="selectSysArticleVo"/>
        where id = #{id}
    </select>
    <select id="readCountWithcollectWithlike" resultMap="SysArticleResult">
        <include refid="selectSysArticleVo"/>
        ORDER BY page_like DESC, page_collect DESC,page_view DESC
            LIMIT 10;
    </select>

    <insert id="insertSysArticle" parameterType="SysArticle" useGeneratedKeys="true" keyProperty="id">
        insert into sys_article
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">title,</if>
            <if test="author != null and author != ''">author,</if>
            <if test="homePage != null and homePage != ''">home_page,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="pageView != null">page_view,</if>
            <if test="introduction != null">introduction,</if>
            <if test="imageText != null">image_text,</if>
            <if test="pageLike != null">page_like,</if>
            <if test="pageCollect != null">page_collect,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="title != null and title != ''">#{title},</if>
            <if test="author != null and author != ''">#{author},</if>
            <if test="homePage != null and homePage != ''">#{homePage},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="pageView != null">#{pageView},</if>
            <if test="introduction != null">#{introduction},</if>
            <if test="imageText != null">#{imageText},</if>
            <if test="pageLike != null">#{pageLike},</if>
            <if test="pageCollect != null">#{pageCollect},</if>
        </trim>
    </insert>

    <update id="updateSysArticle" parameterType="SysArticle">
        update sys_article
        <trim prefix="SET" suffixOverrides=",">
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="author != null and author != ''">author = #{author},</if>
            <if test="homePage != null and homePage != ''">home_page = #{homePage},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="pageView != null">page_view = #{pageView},</if>
            <if test="introduction != null">introduction = #{introduction},</if>
            <if test="imageText != null">image_text = #{imageText},</if>
            <if test="pageLike != null">page_like = #{pageLike},</if>
            <if test="pageCollect != null">page_collect = #{pageCollect},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteSysArticleById" parameterType="Long">
        delete
        from sys_article
        where id = #{id}
    </delete>

    <delete id="deleteSysArticleByIds" parameterType="String">
        delete from sys_article where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>
</mapper>